{
  "name": "fiberglass-react",
  "version": "0.1.0",
  "description": "Drop-in React components and hooks for building Fiber Network payment UX.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup && tailwindcss -c tailwind.config.js -i src/tailwind.css -o dist/styles.css --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "qrcode.react": "^4.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "jsdom": "^26.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.0.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/daodudestiny56-netizen/fibreglass.git"
  },
  "homepage": "https://github.com/daodudestiny56-netizen/fibreglass",
  "bugs": "https://github.com/daodudestiny56-netizen/fibreglass/issues",
  "keywords": [
    "fiber-network",
    "ckb",
    "nervos",
    "payments",
    "react",
    "sdk",
    "lightning"
  ],
  "author": "daodudestiny56-netizen",
  "license": "MIT"
}
